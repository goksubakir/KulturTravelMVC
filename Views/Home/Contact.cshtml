@{
    ViewData["Title"] = "İletişim | Kültür Travel";
    Layout = null; // Kendi header/nav/footer yapısını kullanıyor
}
<!DOCTYPE html>
<html lang="tr">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1.0" />
    <title>@ViewData["Title"]</title>
    <link href="https://fonts.googleapis.com/css2?family=Poppins:wght@400;500;600&display=swap" rel="stylesheet">
    <!-- GENEL CSS -->
    <link rel="stylesheet" href="~/css/style.css" asp-append-version="true" />
</head>
<body>
    <header><h1>Bize Ulaşın</h1></header>

    <nav>
        <a asp-controller="Home" asp-action="Index">Anasayfa</a>
        <a asp-controller="Home" asp-action="About">Hakkımızda</a>
        <a asp-controller="Home" asp-action="Contact" class="active">İletişim</a>
    </nav>

    <!-- 🔹 Üç kutu yan yana -->
    <section style="padding: 40px; display: flex; justify-content: center; gap: 40px; margin: 0 auto; flex-wrap: wrap;">

        <!-- SOL: FORM -->
        <div style="max-width: 400px; background: #fff; border: 2px solid #0077b6; border-radius: 10px; padding: 25px 30px; box-shadow: 0 0 10px rgba(0,0,0,0.1);">
            <form onsubmit="return sendMessage()">
                <label>Ad Soyad:</label><br />
                <input type="text" id="name" required style="width:100%; padding:10px; border:1px solid #ccc; border-radius:5px;" /><br /><br />

                <label>E-posta:</label><br />
                <input type="email" id="email" required style="width:100%; padding:10px; border:1px solid #ccc; border-radius:5px;" /><br /><br />

                <label>Mesajınız:</label><br />
                <textarea id="message" rows="5" required style="width:100%; padding:10px; border:1px solid #ccc; border-radius:5px;"></textarea><br /><br />

                <button type="submit"
                        style="background-color:#0077b6; color:white; border:none; padding:10px; border-radius:5px; width:100%; cursor:pointer;">
                    Gönder
                </button>
            </form>
        </div>

        <!-- ORTA: ADRES -->
        <div style="max-width: 400px; background: #fff; border: 2px solid #0077b6; border-radius: 10px; padding: 25px 30px; box-shadow: 0 0 10px rgba(0,0,0,0.1);">
            <h2 style="color:#0077b6; margin-bottom:20px;">İletişim Bilgilerimiz</h2>

            <p><strong>📍 Adres:</strong><br>
               E5 Karayolu Üzeri Ataköy Yerleşkesi,<br>
               Ataköy 7-8-9-10. Kısım, 34158 Bakırköy / İstanbul</p>

            <p><strong>📞 Telefon:</strong><br>+90 555 123 4567</p>

            <p><strong>✉️ E-posta:</strong><br>info@travelportal.com</p>

            <p><strong>🕒 Çalışma Saatleri:</strong><br>Pazartesi - Cumartesi | 09:00 - 18:00</p>
        </div>

        <!-- SAĞ: HARİTA -->
        <div style="max-width: 400px; background: #fff; border: 2px solid #0077b6; border-radius: 10px; padding: 0; overflow: hidden; box-shadow: 0 0 10px rgba(0,0,0,0.1);">
            <iframe 
                src="https://www.google.com/maps/embed?pb=!1m18!1m12!1m3!1d3011.5516795222225!2d28.829560476113677!3d40.99129682047023!2m3!1f0!2f0!3f0!3m2!1i1024!2i768!4f13.1!3m3!1m2!1s0x14caa35ee1fdc1b1%3A0x658a212e6b4359b5!2zVC5DLiDEsHN0YW5idWwgS8O8bHTDvHIgw5xuaXZlcnNpdGVzaQ!5e0!3m2!1str!2str!4v1761379556149!5m2!1str!2str"
                width="100%"
                height="500"
                allowfullscreen=""
                loading="lazy">
            </iframe>
        </div>

    </section>

    <footer>
        <div class="footer-links">
            <a asp-controller="Home" asp-action="About">Hakkımızda</a> |
            <a asp-controller="Home" asp-action="Contact">Bize Ulaşın</a> |
            <a href="#">Gizlilik Politikası</a> |
            <a href="#">Instagram</a>
        </div>
        <p>&copy; 2025 Travel Portal.</p>
    </footer>

    <!-- CONTACT JS -->
    <script src="~/js/contact.js" asp-append-version="true"></script>
</body>
</html>
